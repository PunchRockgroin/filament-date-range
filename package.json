{
  "name": "filament-date-range",
  "type": "module",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "purge": "npx postcss ./dist/css/date-range-picker.css -o ./dist/css/date-range-picker.css --config ./bin/cssbyebye/",
    "dev:js": "node bin/build.js --dev",
    "dev:css": "tailwindcss -i ./resources/css/date-range-picker.css -o ./dist/css/date-range-picker.css --postcss --minify",
    "dev": "npm run dev:js && npm run dev:css --watch",
    "build:js": "node bin/build.js",
    "build:css": "npx @tailwindcss/cli -i ./resources/css/date-range-picker.css -o ./dist/css/date-range-picker.css --postcss",
    "build": "npm run build:js && npm run build:css && npm run purge"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "dayjs": "^1.11.13"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "css-byebye": "^4.0.1",
    "cssnano": "^8.0.1",
    "esbuild": "^0.25.5",
    "postcss": "^8.5.14",
    "postcss-cli": "^11.0.1",
    "tailwindcss": "^4.1.13"
  }
}
